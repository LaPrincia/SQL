SELECT
    p.provider_id,
    p.provider_name,
    COUNT(e.encounter_id) AS total_encounters,
    AVG(c.total_cost) AS avg_cost_per_encounter,
    AVG(e.length_of_stay) AS avg_los
FROM providers p
JOIN encounters e
    ON p.provider_id = e.provider_id
JOIN costs c
    ON e.encounter_id = c.encounter_id
GROUP BY p.provider_id, p.provider_name
ORDER BY avg_cost_per_encounter DESC;
